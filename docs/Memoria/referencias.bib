@article{edmans_does_2011,
	title = {Does the stock market fully value intangibles? {Employee} satisfaction and equity prices},
	volume = {101},
	issn = {0304-405X},
	shorttitle = {Does the stock market fully value intangibles?},
	url = {https://www.sciencedirect.com/science/article/pii/S0304405X11000869},
	doi = {10.1016/j.jfineco.2011.03.021},
	abstract = {This paper analyzes the relationship between employee satisfaction and long-run stock returns. A value-weighted portfolio of the “100 Best Companies to Work For in America” earned an annual four-factor alpha of 3.5\% from 1984 to 2009, and 2.1\% above industry benchmarks. The results are robust to controls for firm characteristics, different weighting methodologies, and the removal of outliers. The Best Companies also exhibited significantly more positive earnings surprises and announcement returns. These findings have three main implications. First, consistent with human capital-centered theories of the firm, employee satisfaction is positively correlated with shareholder returns and need not represent managerial slack. Second, the stock market does not fully value intangibles, even when independently verified by a highly public survey on large firms. Third, certain socially responsible investing (SRI) screens may improve investment returns.},
	language = {en},
	number = {3},
	urldate = {2023-08-10},
	journal = {Journal of Financial Economics},
	author = {Edmans, Alex},
	month = sep,
	year = {2011},
	keywords = {Human capital, Intangibles, Market efficiency, Socially responsible investing, Underreaction},
	pages = {621--640},
}

@article{hong_price_2009,
	title = {The price of sin: {The} effects of social norms on markets},
	volume = {93},
	issn = {0304-405X},
	shorttitle = {The price of sin},
	url = {https://www.sciencedirect.com/science/article/pii/S0304405X09000634},
	doi = {10.1016/j.jfineco.2008.09.001},
	abstract = {We provide evidence for the effects of social norms on markets by studying “sin” stocks—publicly traded companies involved in producing alcohol, tobacco, and gaming. We hypothesize that there is a societal norm against funding operations that promote vice and that some investors, particularly institutions subject to norms, pay a financial cost in abstaining from these stocks. Consistent with this hypothesis, we find that sin stocks are less held by norm-constrained institutions such as pension plans as compared to mutual or hedge funds that are natural arbitrageurs, and they receive less coverage from analysts than do stocks of otherwise comparable characteristics. Sin stocks also have higher expected returns than otherwise comparable stocks, consistent with them being neglected by norm-constrained investors and facing greater litigation risk heightened by social norms. Evidence from corporate financing decisions and the performance of sin stocks outside the US also suggest that norms affect stock prices and returns.},
	language = {en},
	number = {1},
	urldate = {2023-08-10},
	journal = {Journal of Financial Economics},
	author = {Hong, Harrison and Kacperczyk, Marcin},
	month = jul,
	year = {2009},
	keywords = {Expected stock returns, Institutional ownership, Sin stocks, Social norms},
	pages = {15--36},
}

