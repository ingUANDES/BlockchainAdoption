}

@article{bruno_honey_2022,
	title = {“{Honey}, {I} {Shrunk} the {ESG} {Alpha}”: {Risk}-{Adjusting} {ESG} {Portfolio} {Returns}},
	volume = {31},
	copyright = {© 2022 Pageant Media Ltd},
	issn = {1068-0896, 2168-8613},
	shorttitle = {“{Honey}, {I} {Shrunk} the {ESG} {Alpha}”},
	url = {https://joi.pm-research.com/content/31/3/45},
	doi = {10.3905/joi.2021.1.215},
	abstract = {The authors construct ESG strategies that have been shown to outperform in popular articles. They assess performance benefits to investors when accounting for sector and factor exposures. They find that most of the outperformance of these strategies can be explained by their exposure to equity style factors that are mechanically constructed from balance sheet information. This result is robust across different multifactor models. Furthermore, the ESG strategies tested show large sector biases. Removing these biases also removes outperformance. They conclude that claims on ESG outperformance in popular articles are not valid.},
