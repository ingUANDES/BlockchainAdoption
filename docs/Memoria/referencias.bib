@article{shanaev_when_2022,
	title = {When {ESG} meets {AAA}: {The} effect of {ESG} rating changes on stock returns},
	volume = {46},
	issn = {1544-6123},
	shorttitle = {When {ESG} meets {AAA}},
	url = {https://www.sciencedirect.com/science/article/pii/S1544612321003342},
	doi = {10.1016/j.frl.2021.102302},
	abstract = {This study is the first to employ calendar-time portfolio methodology to investigate the impact of 748 ESG rating changes on stock returns of US firms over 2016–2021. While ESG rating upgrades lead to positive yet inconsistently significant abnormal returns of 0.5\% per month, downgrades are detrimental to stock performance, leading to statistically significant monthly risk-adjusted returns of -1.2\% on average. These findings are more pronounced for ESG leaders than laggards and are robust to various asset-pricing model specifications. The effects of ESG rating levels are modest, with ESG laggards underperforming in risk-adjusted terms.},
	language = {en},
	urldate = {2022-09-22},
	journal = {Finance Research Letters},
	author = {Shanaev, Savva and Ghimire, Binam},
	month = may,
	year = {2022},
	keywords = {Calendar-time portfolio, ESG, ESG investing, ESG rating, Event study, Socially responsible investment},
	pages = {102302},
}

@article{luo_esg_2022,
	title = {{ESG}, liquidity, and stock returns},
	volume = {78},
	issn = {1042-4431},
	url = {https://www.sciencedirect.com/science/article/pii/S104244312200018X},
	doi = {10.1016/j.intfin.2022.101526},
	abstract = {We examine the effect of environment, social, and governance (ESG) score on stock returns in the United Kingdom (UK). Consistent with Hong and Kacperczyk (2009), Bolton and Kacperczyk (2021), and Pedersen et al. (2021), firms with lower ESG earn higher returns than those with higher ESG. The environment and social premiums are more pronounced than the ESG premium. To understand the premium, we show that the ESG premium is significant for low liquidity securities but not for high liquidity securities, which suggests that ESG is likely associated with stock liquidity.},
	language = {en},
	urldate = {2022-09-22},
	journal = {Journal of International Financial Markets, Institutions and Money},
	author = {Luo, Di},
	month = may,
	year = {2022},
	keywords = {ESG, Liquidity, Stock returns},
	pages = {101526},
}

