@article{anderson_cap-and-trade_2025-1,
	title = {Cap-and-{Trade} and {Carbon} {Tax} {Meet} {Arrow}–{Debreu}},
	volume = {93},
	copyright = {© 2025 The Authors. Econometrica published by John Wiley \& Sons Ltd on behalf of The Econometric Society},
	issn = {1468-0262},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.3982/ECTA22923},
	doi = {10.3982/ECTA22923},
	abstract = {We propose two general equilibrium models, quota equilibrium, and emission tax equilibrium. Government specifies quotas or taxes on emissions, and then refrains from further action. All results remain valid regardless of how government chooses its emissions target. Quota equilibrium exists; the allocation of emission property rights impacts the distribution of welfare. If the only externality arises from total net emissions, quota equilibrium is Pareto optimal among all feasible outcomes with the same total net emissions. For certain tax rates, emission tax equilibrium may not exist. Every quota equilibrium can be realized as an emission tax equilibrium and vice versa. However, different quota prices may arise in equilibrium from a single quota, and different emission levels may arise in equilibrium from a single tax rate. This leads to inequivalence between quota and emission tax equilibria.},
	language = {en},
	number = {2},
	urldate = {2025-11-29},
	journal = {Econometrica},
	author = {Anderson, Robert M. and Duanmu, Haosui},
	year = {2025},
	keywords = {Arrow–Debreu model, Cap-and-trade, Pareto optimality, carbon tax, equilibrium existence, equivalence and inequivalence of cap and tax},
	pages = {357--393},
}

