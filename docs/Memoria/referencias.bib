@article{calleja_proportional_2024,
	title = {Proportional clearing mechanisms in financial systems: {An} axiomatic approach},
	volume = {111},
	issn = {0304-4068},
	shorttitle = {Proportional clearing mechanisms in financial systems},
	url = {https://www.sciencedirect.com/science/article/pii/S030440682400017X},
	doi = {10.1016/j.jmateco.2024.102955},
	abstract = {We address the problem of clearing mutual obligations among agents when a financial network collapses. To do so, we adopt an axiomatic approach and provide the first comprehensive characterization of the rules based on the principle of proportionality, covering the entire domain of financial systems. While a previous attempt by Csóka and Herings (2021) tackled this issue in a context where agents have strictly positive initial endowments, we show that their properties do not fully capture the set of proportional rules when extended to the full financial systems’ domain. To overcome this limitation, we introduce new properties that emphasize the value of equity of the firms in the network. We show that a clearing mechanism satisfies compatibility, limited liability, absolute priority, equity continuity, and non-manipulability by clones if and only if each agent receives a payment proportional to the value of their claims. This characterization holds in the framework studied by Csóka and Herings (2021).},
	urldate = {2024-05-27},
	journal = {Journal of Mathematical Economics},
	author = {Calleja, Pedro and Llerena, Francesc},
	month = apr,
	year = {2024},
	keywords = {Axiomatization, Financial systems, Proportional financial rules},
	pages = {102955},
}

@article{csoka_axiomatization_2021,
	title = {An {Axiomatization} of the {Proportional} {Rule} in {Financial} {Networks}},
	volume = {67},
	issn = {0025-1909},
	url = {https://pubsonline.informs.org/doi/10.1287/mnsc.2020.3700},
	doi = {10.1287/mnsc.2020.3700},
	abstract = {The most important rule to determine payments in real-life bankruptcy problems is the proportional rule. Many such bankruptcy problems are characterized by network aspects, and the values of the agents’ assets are endogenous as they depend on the extent to which claims on other agents can be collected. These network aspects make an axiomatic analysis challenging. This paper is the first to provide an axiomatization of the proportional rule in financial networks. Our main axiom is invariance to mitosis. The other axioms are claims boundedness, limited liability, priority of creditors, continuity, and impartiality.

This paper was accepted by Manel Baucells, decision analysis.},
	number = {5},
	urldate = {2024-05-27},
	journal = {Management Science},
	author = {Csóka, Péter and Herings, P. Jean-Jacques},
	month = may,
	year = {2021},
	note = {Publisher: INFORMS},
	keywords = {C71, G10, bankruptcy rules, financial networks, proportional rule, systemic risk},
	pages = {2799--2812},
}

@article{he_public_2024,
	title = {Public goods provision in a network formation game},
	volume = {218},
	issn = {0167-2681},
	url = {https://www.sciencedirect.com/science/article/pii/S0167268123004353},
	doi = {10.1016/j.jebo.2023.11.029},
	abstract = {This study investigates how people provide public goods in a network formation game. In this game, players form a network through bilateral linking, with or without a link cost; the players then contribute to a public good, which can benefit both themselves and their direct neighbors. Theoretically, two equilibrium goods provision strategies exist: splitting and alternation. Efficient networks are conditioned on a goods provision strategy and are less dense when the link cost increases. Our laboratory experiment indicates that subjects predominantly converge to splitting instead of alternation and can often form efficient networks. Subjects form fewer links under a higher link cost and tend to form too many links.},
	urldate = {2024-05-20},
	journal = {Journal of Economic Behavior \& Organization},
	author = {He, Simin and Zou, Xinlu},
	month = feb,
	year = {2024},
	keywords = {Coordination complexity, Laboratory experiment, Network formation, Public goods, Repeated games},
	pages = {104--131},
}

@article{bramoulle_public_2007,
	title = {Public goods in networks},
	volume = {135},
	issn = {0022-0531},
	url = {https://www.sciencedirect.com/science/article/pii/S0022053106001220},
	doi = {10.1016/j.jet.2006.06.006},
	abstract = {This paper considers incentives to provide goods that are non-excludable along social or geographic links. We find, first, that networks can lead to specialization in public good provision. In every social network there is an equilibrium where some individuals contribute and others free ride. In many networks, this extreme is the only outcome. Second, specialization can benefit society as a whole. This outcome arises when contributors are linked, collectively, to many agents. Finally, a new link increases access to public goods, but reduces individual incentives to contribute. Hence, overall welfare can be higher when there are holes in a network.},
	number = {1},
	urldate = {2024-05-20},
	journal = {Journal of Economic Theory},
	author = {Bramoullé, Yann and Kranton, Rachel},
	month = jul,
	year = {2007},
	keywords = {Experimentation, Independent sets, Information sharing, Strategic substitutes},
	pages = {478--494},
}

@article{chandrasekhar_testing_2020,
	title = {Testing {Models} of {Social} {Learning} on {Networks}: {Evidence} {From} {Two} {Experiments}},
	volume = {88},
	issn = {0012-9682},
	shorttitle = {Testing {Models} of {Social} {Learning} on {Networks}},
	url = {https://www.econometricsociety.org/doi/10.3982/ECTA14407},
	doi = {10.3982/ECTA14407},
	abstract = {We theoretically and empirically study an incomplete information model of social learning. Agents initially guess the binary state of the world after observing a private signal. In subsequent rounds, agents observe their network neighbors' previous guesses before guessing again. Agents are drawn from a mixture of learning types—Bayesian, who face incomplete information about others' types, and DeGroot, who average their neighbors' previous period guesses and follow the majority. We study (1) learning features of both types of agents in our incomplete information model; (2) what network structures lead to failures of asymptotic learning; (3) whether realistic networks exhibit such structures. We conducted lab experiments with 665 subjects in Indian villages and 350 students from ITAM in Mexico. We perform a reduced‐form analysis and then structurally estimate the mixing parameter, finding the share of Bayesian agents to be 10\% and 50\% in the Indian‐villager and Mexican‐student samples, respectively.},
	language = {en},
	number = {1},
	urldate = {2024-05-20},
	journal = {Econometrica},
	author = {Chandrasekhar, Arun G. and Larreguy, Horacio and Xandri, Juan Pablo},
	year = {2020},
	pages = {1--32},
}

@article{bich_existence_2020,
	title = {On the {Existence} of {Pairwise} {Stable} {Weighted} {Networks}},
	volume = {45},
	issn = {0364-765X},
	url = {https://pubsonline.informs.org/doi/10.1287/moor.2019.1032},
	doi = {10.1287/moor.2019.1032},
	abstract = {In network theory, Jackson and Wolinsky introduced a now widely used notion of stability for unweighted network formation called pairwise stability. We prove the existence of pairwise stable weighted networks under assumptions on payoffs that are similar to those in Nash's and Glicksberg’s existence theorem (continuity and quasi concavity). Then, we extend our result, allowing payoffs to depend not only on the network, but also on some game-theoretic strategies. The proof is not a standard application of tools from game theory, the difficulty coming from the fact that the pairwise stability notion has both cooperative and noncooperative features. Last, some examples are given and illustrate how our results may open new paths in the literature on network formation.},
	number = {4},
	urldate = {2024-05-20},
	journal = {Mathematics of Operations Research},
	author = {Bich, Philippe and Morhaim, Lisa},
	month = nov,
	year = {2020},
	note = {Publisher: INFORMS},
	keywords = {Primary: 90B10, 91D30, 91A40, 91A43, 91B50, 91B52, Primary: Networks/graphs/theory/games/group decisions/cooperative and noncooperative, pairwise stable network, weighted network},
	pages = {1393--1404},
}

@article{crettez_general_2022,
	title = {General equilibrium cryptocurrency pricing in an {OLG} model},
	volume = {117},
	issn = {0165-4896},
	url = {https://www.sciencedirect.com/science/article/pii/S0165489622000142},
	doi = {10.1016/j.mathsocsci.2022.02.003},
	abstract = {We study the valorization of cryptocurrency in an overlapping generations model where agents have the choice between crypto- and central bank currency. We pay attention to three features of cryptocurrency: it is a risky asset (because of frauds and hacks), which one acquires by bearing transaction costs, and its supply reaches its upper limit in a finite time (e.g., Bitcoin). We consider both the standard case with linear–quadratic utility functions and the more general case where utility functions are not specified. We find that the effect of an increase in cryptocurrency on the currency prices depends on the transaction costs that individuals bear to get cryptocurrency. In particular, when these costs are convex non-increasing in the quantity of cryptocurrency, the cryptocurrency price may increase with this quantity. Otherwise, when the transaction costs are either increasing or concave non-increasing, the cryptocurrency price decreases with the quantity of cryptocurrency. We also show that the cryptocurrency and the central bank currency prices always move in opposite directions.},
	urldate = {2024-05-20},
	journal = {Mathematical Social Sciences},
	author = {Crettez, Bertrand and Morhaim, Lisa},
	month = may,
	year = {2022},
	keywords = {Asset pricing, Central bank currency, Cryptocurrency, General equilibrium, Overlapping generations model},
	pages = {13--19},
}

