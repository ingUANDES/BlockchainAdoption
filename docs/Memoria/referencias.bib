@article{arseneau_private_2020,
	title = {Private and public liquidity provision in over-the-counter markets},
	volume = {15},
	issn = {1555-7561},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.3982/TE3419},
	doi = {10.3982/TE3419},
	abstract = {We show that trade frictions in over-the-counter (OTC) markets result in inefficient private liquidity provision. We develop a dynamic model of market-based financial intermediation with a two-way interaction between primary credit markets and secondary OTC markets. Private allocations are generically inefficient due to a congestion externality operating through market liquidity in the OTC market. This inefficiency can lead to liquidity that is suboptimally low or high compared to the second best, providing a rationale for the regulation and public provision of liquidity. Moreover, our model characterizes a transmission channel of quantitative easing or tightening that operates through liquidity premia.},
	language = {en},
	number = {4},
	urldate = {2022-06-28},
	journal = {Theoretical Economics},
	author = {Arseneau, David M. and Rappoport W., David E. and Vardoulakis, Alexandros P.},
	year = {2020},
	keywords = {E44, G18, G30, Liquidity provision, market liquidity, monetary policy normalization, over-the-counter markets, quantitative easing, quantitative tightening},
	pages = {1669--1712},
}

