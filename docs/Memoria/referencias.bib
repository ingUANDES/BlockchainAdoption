	author = {Franco-Watkins, Ana M. and Johnson, Joseph G.},
	month = sep,
	year = {2011},
	keywords = {Attention, Cognition, Cognitive Control, Cognitive Psychology, Decision Making, Decision making, Eye tracking, Information Processing, Methods, Psychometrics},
	pages = {853--863},
}

