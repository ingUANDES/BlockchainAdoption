	month = jan,
	year = {2010},
	doi = {10.1016/B978-0-444-50897-3.50013-4},
	pages = {553--615},
}

@incollection{christoffersen_2_2012,
	address = {San Diego},
	title = {2 - {Historical} {Simulation}, {Value}-at-{Risk}, and {Expected} {Shortfall}},
