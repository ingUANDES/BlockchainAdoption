@article{chen_renewable_2021,
	title = {Renewable energy investment and carbon emissions under cap-and-trade mechanisms},
	volume = {278},
	issn = {0959-6526},
	url = {https://www.sciencedirect.com/science/article/pii/S0959652620333862},
	doi = {10.1016/j.jclepro.2020.123341},
	abstract = {This paper develops a model to examine the impacts of cap-and-trade mechanisms on the decisions of a utility firm when it invests in renewable energy and has an existing conventional energy source. Three cap-and-trade mechanisms are considered, No cap-and-trade Mechanism (NM), Grandfathering Mechanism (GM), and Benchmarking Mechanism (BM). We find that the utility firm invests more in renewable energy under either a GM or a BM than that under NM. As compared to GM, the utility firm under the BM invests more in renewable energy, while at the same time it generates more carbon emissions. We also show that investment in renewable energy does not necessarily reduce carbon emissions. When the government sets the unit carbon quota appropriately, however, BM can not only achieve a reduction in carbon emissions, but also ensure that electricity demand will not decrease. The implementation of BM can make the utility firm invest most heavily in renewable energy, while the implementation of GM will produce the lowest carbon emissions. When either a GM or a BM implemented under a lenient unit carbon quota (or total carbon quota), the utility firm can be more profitable. The study provides some new management insights for the policy-maker.},
	language = {en},
	urldate = {2021-08-23},
	journal = {Journal of Cleaner Production},
	author = {Chen, Wei and Chen, Jing and Ma, Yongkai},
	month = jan,
	year = {2021},
	keywords = {Benchmarking mechanism, Cap-and-trade mechanism, Carbon emissions, Grandfathering mechanism, Renewable energy investment},
	pages = {123341},
}

