	issn = {2199-6776},
	url = {https://doi.org/10.1007/s40881-024-00170-w},
	doi = {10.1007/s40881-024-00170-w},
	abstract = {We introduce a novel way to elicit individuals’ strength of altruistic motivation in the context of charitable donations, ranging from pure warm glow to pure altruism. Using the giving-type elicitation task of Gangadharan et al. (2018) and assuming that individuals maximise a Cobb–Douglas impure altruism utility function, as is used in Ottoni-Wilhelm et al. (2017), we can uniquely identify the strength of altruistic motivation for impure altruists, which is typically found to be the largest category of donors. We compare the introduced measure to an alternative survey-based elicitation from Carpenter (2021).},
