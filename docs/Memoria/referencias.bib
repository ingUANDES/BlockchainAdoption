	pmid = {30282741},
	keywords = {environmental groups, nonprofits, private provision, public goods, water quality},
	pages = {5334--5340},
}

@article{mcbride_discrete_2006,
	title = {Discrete public goods under threshold uncertainty},
	volume = {90},
	issn = {0047-2727},
	url = {http://www.sciencedirect.com/science/article/pii/S0047272705001568},
	doi = {10.1016/j.jpubeco.2005.09.012},
	abstract = {A discrete public good is provided when total contributions exceed the contribution threshold, yet the threshold is often not known with certainty. I show that the relationship between the degree of threshold uncertainty and equilibrium contributions and welfare is not monotonic. For a large class of threshold probability distributions, equilibrium contributions will be higher under increased uncertainty (e.g., a mean-preserving spread) if the public good's value is sufficiently high. Otherwise, and if another condition on the distribution's mode is met, contributions will be lower. The same result also obtains if a single-crossing condition of the pdfs is met.},
	number = {6},
	urldate = {2019-04-19},
	journal = {Journal of Public Economics},
	author = {McBride, Michael},
	month = aug,
	year = {2006},
	keywords = {Collective action, Participation},
	pages = {1181--1199},
}

@article{feldstein_income_1976,
	title = {The {Income} {Tax} and {Charitable} {Contributions}},
