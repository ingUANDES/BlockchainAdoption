@misc{burone_measuring_2023,
	title = {Measuring multidimensional well-being when preferences differ: a non-parametric approach},
	abstract = {In this paper, we present a multidimensional well-being measure that respects individual preference heterogeneity, even when these preferences are incomplete. We discuss how the proposed well-being measure can be implemented in a non-parametric way, using the Adaptive Bisectional Dichotomous Choice (ABDC) method (Decancq and Nys, 2021). the ABDC method consists of two steps. In the first step, respondents are presented with a series of dichotomous choices between pairs of life situations that consist of their actual and hypothetical life situations. The hypothetical life situations are obtained using the adaptive bisectional algorithm. This algorithm proceeds iteratively and generates, in each iteration, a hypothetical life situation that is situated in the middle of the interval where the indifference curve should be, based on the responses to previous choices. Considering three dimensions of well-being (income, health, and social relationships) we measure well-being for a final sample of 2288 Dutch citizens. ∗Financial support of the Research Foundation - Flanders is gratefully acknowledged. †Centre for Social Policy Herman Deleeck (University of Antwerp) ‡Centre for Social Policy Herman Deleeck (University of Antwerp), Centre for Philosophy of Natural and Social Science (London School of Economics), CORE (Universit´e catholique de Louvain-la-Neuve), and Department of Economics (KULeuven).},
	language = {en},
	author = {Burone, Santiago and Decancq, Koen},
	year = {2023},
	keywords = {equivalence approach},
}

@article{lee_impact_2023,
