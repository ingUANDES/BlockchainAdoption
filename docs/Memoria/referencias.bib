@article{lopez_investment_2021,
	title = {Investment performance, regulation and incentives: the case of {Chilean} pension funds},
	volume = {20},
	issn = {1474-7472, 1475-3022},
	shorttitle = {Investment performance, regulation and incentives},
	url = {https://www.cambridge.org/core/product/identifier/S1474747219000350/type/journal_article},
