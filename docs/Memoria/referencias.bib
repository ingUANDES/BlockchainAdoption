	keywords = {Lindahl equilibrium, Public good economies, Ratio equilibrium},
	pages = {335--362},
}

@article{tarbush_social_2017,
	series = {John {Nash} {Memorial}},
	title = {Social groups and social network formation},
	volume = {103},
	issn = {0899-8256},
	url = {http://www.sciencedirect.com/science/article/pii/S0899825615001529},
	doi = {10.1016/j.geb.2015.11.004},
	abstract = {We present a dynamic model of social network formation in which a fixed number of agents interact in overlapping social groups. We derive several results on the formation of links in such networks, including results on the degree distribution, on comparative statics relating degree and group size, and on the dynamics of homophily. In particular, we derive comparative statics showing that degree is typically positively related to social group size but negatively related to the size of the overlap across multiple social groups. This is supported by evidence from a Facebook dataset. We also show that homophily over an agent's lifespan in the network can be non-monotonic, reaching a global maximum in some period before eventually decreasing.},
	number = {Supplement C},
	urldate = {2017-10-24},
	journal = {Games and Economic Behavior},
	author = {Tarbush, Bassel and Teytelboym, Alexander},
	month = may,
	year = {2017},
	keywords = {Dynamic network formation, Homophily, Social groups, Social networks},
	pages = {286--312},
}

@article{nitzan_private_1990,
	title = {Private provision of a discrete public good with uncertain cost},
	volume = {42},
	issn = {0047-2727},
	url = {http://www.sciencedirect.com/science/article/pii/0047272790900219},
	doi = {10.1016/0047-2727(90)90021-9},
	abstract = {It is known that a discrete public good is efficiently provided in the subset of ‘undominated equilibria’ (those not Pareto dominated within the set of Nash equilibria). We make the cost of the discrete public good uncertain at the time the contribution game is played. This can lead to strikingly different results. Often, the public good is underprovided in any Nash equilibrium and there is a unique undominated equilibrium. These results hold for some distributions when there is arbitrarily little uncertainty and always when there is enough uncertainty.},
	number = {3},
	urldate = {2019-04-04},
	journal = {Journal of Public Economics},
	author = {Nitzan, Shmuel and Romano, Richard E.},
	month = aug,
	year = {1990},
	pages = {357--370},
}

@article{haimanko_voluntary_2004,
	title = {Voluntary formation of communities for the provision of public projects},
	volume = {115},
	issn = {0022-0531},
	url = {http://www.sciencedirect.com/science/article/pii/S0022053103001339},
	doi = {10.1016/S0022-0531(03)00133-9},
	abstract = {In this paper we examine a group formation problem, where heterogeneous individuals partitioned themselves into communities, each choosing its own public project from the given space of feasible projects. The model is that of “horizontal product differentiation” where individuals display distinct preferences over the policy space. We consider the notion of “efficient” configuration that minimizes the total project-related costs and aggregate personalized costs of all individuals, and “sustainable” configurations, those are immune against breakaways by subgroups of individuals. Our main result is that, with a unidimensional project space and single-peaked personalized costs, every efficient partition is sustainable.},
	number = {1},
	urldate = {2019-03-30},
	journal = {Journal of Economic Theory},
	author = {Haimanko, Ori and Le Breton, Michel and Weber, Shlomo},
