@incollection{andreozzi_fashion_2007,
	address = {Bingley},
	title = {Fashion: {Why} {People} {Like} it and {Theorists} do not},
	volume = {10},
	isbn = {978-0-7623-1452-2},
	shorttitle = {Fashion},
	url = {https://www.emerald.com/insight/content/doi/10.1016/S1529-2134(07)10009-0/full/html},
	abstract = {One of the many paradoxes of fashions is that consumers’ choices change rapidly and with an astonishing degree of synchronization. What is successful or socially acceptable in one period is considered the opposite in the next. This paradox has brought economists and other social scientists to conceive of fashions and fads as one of many forms of irrational behavior. Herd behavior and weakness of will, a desire to conform or, conversely, to distinguish oneself, have all been invoked to explain the rapid evolution of modes of behavior that emerge and more or less suddenly disappear. In this paper we try to show that fashions, even if fragile and transient, might nonetheless be rational. It is a rationality, however, that has to include something overlooked in most economic writing: the desire for novelty and variety. In fashions this desire takes the form of coordinated behavior that both facilitates consumption and destroys its novel content, thus paving the way for new fashions to appear.},
	language = {en},
	urldate = {2020-11-02},
	booktitle = {Advances in {Austrian} {Economics}},
	publisher = {Emerald (MCB UP )},
	author = {Andreozzi, Luciano and Bianchi, Marina},
	year = {2007},
	doi = {10.1016/S1529-2134(07)10009-0},
	pages = {209--229},
}

@unpublished{minardi_consumption_2020,
	title = {Consumption of values},
	url = {https://3aa7ecdb-a-62cb3a1a-s-sites.googlegroups.com/site/stefaniaminardi/research/gmw_consumption_of_values.pdf?1582640022868%3Fattredirects=0&attachauth=ANoY7cqh8cFBL8NbHPWZTsze45K8DExfygrC4-jwklLlVMyVZfbVNIdZt5uf7cPf9kPBDtNcI6WGvyi474QyG33_XO3E5fAupQuAHbYGMY6b2SEZi0BnfKvzDnSyL2iCjeW5XP3si8NEnFyjTzMQ49nKFo7oshUhDYvcH2hjhHg5QR0o0xFJgC2EQKzbiFlPKoD10ufi1HNJT1cnI4bJ9CC1XbOB8uXyOT0oNk8KL9b137_KDax7kQMjz4mzJWcKibxG7eazz3Qr&attredirects=0},
	abstract = {Consumption decisions are partly ináuenced by values and ideologies. Consumers care about global warming as well as about child
labor and fair trade. Incorporating values into the consumerís utility
function will often violate monotonicity, in case consumption hurts
cherished values in a way that isnít o§set by the hedonic beneÖts of
material consumption. We distinguish between intrinsic and instrumental values, and argue that the former tend to introduce discontinuities near zero. For example, a vegetarianís preferences would be
discontinuous near zero amount of animal meat. We axiomatize a
utility representation that captures such preferences and discuss the
measurability of the degree to which consumers care about such values.},
	urldate = {2020-11-02},
	author = {Minardi, Stefania and Gilboa, Itzhak and Wang, Fang},
	month = aug,
	year = {2020},
}

@article{fischman_debate_nodate,
	title = {Debate: {Mental} health, social crisis and the {COVID}-19 pandemic in {Chile}},
	issn = {1475-357X},
	doi = {10.1111/camh.12424},
	abstract = {Mental health in Chile has been significantly challenged by the beginning of a social crisis in October of 2019 and the COVID-19 pandemic of 2020. Despite widening of shortage of services, both the burgeoning of Telepsychiatry and a Presidential Initiative to integrate mental health to policy making and services provided by all sectors of government have mitigated the effects of this crisis.},
	journal = {CHILD AND ADOLESCENT MENTAL HEALTH},
	author = {Fischman, Patricio and Irarrazaval, Matias},
}

@article{caqueo-urizar_mental_2020,
	title = {Mental {Health} and the {COVID}-19 {Pandemic} in {Chile}},
	volume = {12},
	issn = {1942-9681},
	doi = {10.1037/tra0000753},
	abstract = {With one of the highest testing rates of COVID-19 in Latin America, Chile continues to record low mortality rates from the disease. Several measures such as curfews, cancellation of large gatherings, and closure of schools and businesses have been implemented. Against the backdrop of high levels of alcohol/substance abuse, mental health disorders, and inequalities across Chile, it is likely that levels of stress and anxiety will peak during the COVID-19 pandemic. As key public health responses such as testing, contact tracing, isolation and management of confirmed cases of COVID-19 are being ramped up, it is expedient to prioritize measures to safeguard the mental health of Chileans.},
	number = {5},
	journal = {PSYCHOLOGICAL TRAUMA-THEORY RESEARCH PRACTICE AND POLICY},
	author = {Caqueo-Urizar, Alejandra and Urzua, Alfonso and Aragon-Caqueo, Diego and Charles, Carlo Handy and El-Khatib, Ziad and Otu, Akaninyene and Yaya, Sanni},
	month = jul,
