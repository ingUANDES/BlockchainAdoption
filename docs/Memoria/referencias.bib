	keywords = {ESG, beliefs, governance, managers, social responsibility},
	pages = {1340820},
}

@article{dardati_cap-and-trade_2016,
	title = {Cap-and-{Trade} and {Financial} {Constraints}: {Is} {Investment} {Independent} of {Permit} {Holdings}?},
