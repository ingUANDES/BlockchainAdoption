@incollection{gourieroux_chapter_2010,
	address = {San Diego},
	series = {Handbooks in {Finance}},
	title = {{CHAPTER} 10 - {Value} at {Risk}},
	volume = {1},
	url = {https://www.sciencedirect.com/science/article/pii/B9780444508973500134},
	abstract = {This chapter is a survey of literature on the management, supervision, and measurement of extreme and infrequent risks in finance. Extreme risks are the risks of very large losses per dollar invested. As losses associated to extreme risks occur infrequently, investors tend to become less alert to these risks over time. A series of bank failures, due to mismanaged portfolios of corporate loans, real estate, and complex derivatives, was a painful reminder of the existence of extreme risks. It prompted new regulations and research on new instruments of risk protection. The implementation of the common guidelines for risk supervision was a very ambitious initiative designed to address a variety of risks. These risks can be divided into three categories: market risk, credit risk or risk of default, and liquidity risk or risk of counterparty. In 1995, the governors of Central Banks gathered in Basle (Switzerland) and adopted a mandatory risk measure called the Value at Risk to be calculated by all banks for each line of their balance sheets. Since then, banks have been required to report the Value at Risk to the regulators and update it daily and hold a sufficient amount of capital (the so-called required capital) as a hedge against extreme risks.},
	language = {en},
	urldate = {2021-11-08},
	booktitle = {Handbook of {Financial} {Econometrics}: {Tools} and {Techniques}},
	publisher = {North-Holland},
	author = {Gourieroux, Christian and Jasiak, Joann},
	editor = {Aït-sahalia, YACINE and Hansen, LARS PETER},
	month = jan,
	year = {2010},
	doi = {10.1016/B978-0-444-50897-3.50013-4},
	pages = {553--615},
}

@incollection{christoffersen_2_2012,
	address = {San Diego},
	title = {2 - {Historical} {Simulation}, {Value}-at-{Risk}, and {Expected} {Shortfall}},
	isbn = {978-0-12-374448-7},
	url = {https://www.sciencedirect.com/science/article/pii/B9780123744487000026},
	abstract = {This chapter introduces the most commonly used method for computing value-at-risk (VaR), historical simulation, and discusses the pros and cons of this method. Historical simulation (HS) is widely used in practice because of two reasons: the ease with which it is implemented and its model-free nature. The HS technique is very easy to implement, there are no parameters that are to be estimated by maximum likelihood or any other method; therefore, no numerical optimization is performed. The HS technique is modelfree, as it does not rely on any particular parametric model such as a RiskMetrics model for variance and a normal distribution for the standardized returns. VaR is the most popular risk measure in use and HS is the most often used methodology to compute VaR.},
	language = {en},
	urldate = {2021-11-08},
	booktitle = {Elements of {Financial} {Risk} {Management} ({Second} {Edition})},
	publisher = {Academic Press},
	author = {Christoffersen, Peter F.},
	editor = {Christoffersen, Peter F.},
