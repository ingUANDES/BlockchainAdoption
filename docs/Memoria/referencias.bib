@unpublished{minardi_consumption_2020,
	title = {Consumption of values},
	url = {https://3aa7ecdb-a-62cb3a1a-s-sites.googlegroups.com/site/stefaniaminardi/research/gmw_consumption_of_values.pdf?1582640022868%3Fattredirects=0&attachauth=ANoY7cqh8cFBL8NbHPWZTsze45K8DExfygrC4-jwklLlVMyVZfbVNIdZt5uf7cPf9kPBDtNcI6WGvyi474QyG33_XO3E5fAupQuAHbYGMY6b2SEZi0BnfKvzDnSyL2iCjeW5XP3si8NEnFyjTzMQ49nKFo7oshUhDYvcH2hjhHg5QR0o0xFJgC2EQKzbiFlPKoD10ufi1HNJT1cnI4bJ9CC1XbOB8uXyOT0oNk8KL9b137_KDax7kQMjz4mzJWcKibxG7eazz3Qr&attredirects=0},
	abstract = {Consumption decisions are partly ináuenced by values and ideologies. Consumers care about global warming as well as about child labor and fair trade. Incorporating values into the consumerís utility function will often violate monotonicity, in case consumption hurts cherished values in a way that isnít o§set by the hedonic beneÖts of material consumption. We distinguish between intrinsic and instrumental values, and argue that the former tend to introduce discontinuities near zero. For example, a vegetarianís preferences would be discontinuous near zero amount of animal meat. We axiomatize a utility representation that captures such preferences and discuss the measurability of the degree to which consumers care about such values.},
	urldate = {2020-11-02},
	author = {Minardi, Stefania and Gilboa, Itzhak and Wang, Fang},
	month = aug,
	year = {2020},
}

@incollection{andreozzi_fashion_2007,
	address = {Bingley},
	title = {Fashion: {Why} {People} {Like} it and {Theorists} do not},
	volume = {10},
	isbn = {978-0-7623-1452-2},
	shorttitle = {Fashion},
	url = {https://www.emerald.com/insight/content/doi/10.1016/S1529-2134(07)10009-0/full/html},
	abstract = {One of the many paradoxes of fashions is that consumers’ choices change rapidly and with an astonishing degree of synchronization. What is successful or socially acceptable in one period is considered the opposite in the next. This paradox has brought economists and other social scientists to conceive of fashions and fads as one of many forms of irrational behavior. Herd behavior and weakness of will, a desire to conform or, conversely, to distinguish oneself, have all been invoked to explain the rapid evolution of modes of behavior that emerge and more or less suddenly disappear. In this paper we try to show that fashions, even if fragile and transient, might nonetheless be rational. It is a rationality, however, that has to include something overlooked in most economic writing: the desire for novelty and variety. In fashions this desire takes the form of coordinated behavior that both facilitates consumption and destroys its novel content, thus paving the way for new fashions to appear.},
	language = {en},
	urldate = {2020-11-02},
	booktitle = {Advances in {Austrian} {Economics}},
	publisher = {Emerald (MCB UP )},
	author = {Andreozzi, Luciano and Bianchi, Marina},
	year = {2007},
	doi = {10.1016/S1529-2134(07)10009-0},
	pages = {209--229},
}

@article{unal_taxonomy_2019,
	title = {A taxonomy of circular economy implementation strategies for manufacturing firms: {Analysis} of 391 cradle-to-cradle products},
	volume = {212},
	issn = {0959-6526},
	doi = {10.1016/j.jclepro.2018.11.291},
	abstract = {Given the complexity of circular economy implementation, the literature is missing a strategic stand-point. This paper investigates the taxonomy of circular economy implementation strategies at the managerial level by linking it to strategy literature. The taxonomy was developed by using standard k-mean clustering method that incorporates 391 Cradle-to-Cradle product scorecards of 187 companies from 10 different industries. The analysis was based on the relative importance assigned to each competitive capability that defines the circular economy; namely, material health, material reutilization, renewable energy, water stewardship, and social fairness. Three distinct clusters of circular economy implementation strategy groups were observed: (i) founding (recyclers), (ii) development (all-decent circulars), and (iii) maturity (toxicity fighters). All clusters have been present in various industries, although there is an industry effect. The results indicate that each cluster has a different strategy. The results obtained contradict the general assumption and expectation of simultaneous improvement at all circular economy dimensions. Our research contributes to the theoretical understanding of circular economy implementation by providing a taxonomy of strategies. It contributes to the strategy literature by suggesting that the maturity degree of a competitive capability may determine the implementation strategy. For practice, the study presents a road-map for managers to reach higher degrees of circularity. (C) 2018 Elsevier Ltd. All rights reserved.},
	language = {English},
	journal = {JOURNAL OF CLEANER PRODUCTION},
	author = {Unal, Enes and Shao, Jing},
	month = mar,
	year = {2019},
	keywords = {Circular business model, Circular economy, Circular economy implementation, Circular value configuration, Cradle-to-Cradle, Strategy},
	pages = {754--765},
}

